rules_version = '2';

// ============================================================
//  FIRESTORE SECURITY RULES — ADCM Poá
//  CORRIGIDO: escrita restrita ao UID do admin via /admins/{uid}
//  Para registrar um admin, crie o documento manualmente no
//  Console do Firebase: /admins/{UID_DO_USUARIO} com isAdmin: true
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: verifica se o usuário é admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Coleções públicas — qualquer visitante pode LER, somente admin escreve
    match /cultos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /avisos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ministerios/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testemunhos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configurações do site (hero, endereço, live, sobre, reciclagem)
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pedidos de oração — qualquer visitante pode CRIAR, somente admin lê/gerencia
    match /pedidos_oracao/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Tabela de admins — apenas o próprio admin pode ler seu registro
    // Nunca permitir escrita pelo frontend (somente via Console do Firebase)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Bloquear qualquer outra coleção por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
