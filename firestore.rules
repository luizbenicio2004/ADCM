rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Coleções públicas — qualquer visitante pode LER, somente admin escreve
    match /cultos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /eventos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /avisos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /ministerios/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Configurações do site (hero, endereço, live, sobre, reciclagem)
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bloquear qualquer outra coleção por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
